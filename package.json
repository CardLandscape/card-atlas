{
  "name": "card-atlas",
  "version": "1.0.0",
  "description": "银行卡产品资料库 - 按银行、卡组织、卡等级分类",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vue-tsc --noEmit && vite build",
    "build:electron": "npm run build && electron-builder --config electron/electron-builder.yml",
    "build:electron:win": "npm run build && electron-builder --win --config electron/electron-builder.yml",
    "build:electron:mac": "npm run build && electron-builder --mac --config electron/electron-builder.yml",
    "build:electron:linux": "npm run build && electron-builder --linux --config electron/electron-builder.yml",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "element-plus": "^2.6.0",
    "@element-plus/icons-vue": "^2.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vue-tsc": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.0",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}